{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VibeCut Studio",
  "version": "0.1.0",
  "identifier": "com.vibecut.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VibeCut Studio",
        "width": 1540,
        "height": 960,
        "minWidth": 1280,
        "minHeight": 760,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
